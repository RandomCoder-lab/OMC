# substrate_rag.omc
# Phi-Pi-Fibonacci RAG (Retrieval-Augmented Generation) using native substrate_embed.
# The native substrate_embed builtin (no API key, pure math) powers all retrieval.

import "examples/lib/llm.omc"
import "examples/lib/cache.omc" as cache

h MODEL = "claude-opus-4-5"
h EMBED_CACHE = cache.lru_new(500)

# ── Embedding helpers ─────────────────────────────────────────────────────────

fn embed_cached(text) {
    h cached = cache.lru_get(EMBED_CACHE, text)
    if cached != null { return cached }
    h v = substrate_embed(text, 16)
    cache.lru_put(EMBED_CACHE, text, v)
    return v
}

fn cosine_sim(a, b) {
    h dot = 0.0
    h i = 0
    h min_len = arr_len(a)
    if arr_len(b) < min_len { min_len = arr_len(b) }
    while i < min_len {
        dot += a[i] * b[i]
        i += 1
    }
    return dot
}

# ── Document store ────────────────────────────────────────────────────────────

fn docstore_new() {
    return {docs: [], embeddings: [], metadata: []}
}

fn docstore_add(store, text, meta) {
    h embedding = embed_cached(text)
    arr_push(store["docs"], text)
    arr_push(store["embeddings"], embedding)
    h m = meta
    if m == null { m = {} }
    arr_push(store["metadata"], m)
    return null;
}

fn docstore_search(store, query, top_k) {
    h query_embed = embed_cached(query)
    h scores = []
    h i = 0
    while i < arr_len(store["docs"]) {
        h csim = cosine_sim(query_embed, store["embeddings"][i])
        arr_push(scores, {idx: i, score: csim})
        i += 1
    }
    # bubble-sort descending
    h n = arr_len(scores)
    h si = 0
    while si < n {
        h sj = si + 1
        while sj < n {
            if scores[sj]["score"] > scores[si]["score"] {
                h tmp = scores[si]
                scores[si] = scores[sj]
                scores[sj] = tmp
            }
            sj += 1
        }
        si += 1
    }
    h k = top_k
    if k > n { k = n }
    h results = []
    h ri = 0
    while ri < k {
        h idx = scores[ri]["idx"]
        arr_push(results, {
            text: store["docs"][idx],
            score: scores[ri]["score"],
            metadata: store["metadata"][idx]
        })
        ri += 1
    }
    return results
}

# ── RAG pipeline ─────────────────────────────────────────────────────────────

fn rag_answer(store, question, top_k, model) {
    h m = model
    if m == null { m = MODEL }
    h retrieved = docstore_search(store, question, top_k)
    h context_parts = []
    h i = 0
    while i < arr_len(retrieved) {
        arr_push(context_parts, str_concat(
            "[Doc ", to_string(i + 1), " | sim=", to_string(retrieved[i]["score"]), "]\n",
            retrieved[i]["text"]
        ))
        i += 1
    }
    h context = arr_join(context_parts, "\n\n")
    h sys = "You are a helpful assistant. Answer questions based only on the provided context. Be concise."
    h prompt = str_concat(
        "Context:\n", context, "\n\n",
        "Question: ", question, "\n\n",
        "Answer based only on the context above."
    )
    h answer = llm_call(prompt, m, sys)
    return {answer: answer, retrieved: retrieved, question: question}
}

# ── Knowledge base ────────────────────────────────────────────────────────────

h KB = docstore_new()

h DOCUMENTS = [
    {
        text: "OMC (OmniMCode) is a self-hosting harmonic computing language. It uses phi-pi-fibonacci substrate mathematics as its computational foundation. OMC can call external LLMs via llm_call and execute generated code via eval_omc.",
        meta: {source: "OMC intro", topic: "language"}
    },
    {
        text: "The phi-pi-fibonacci substrate uses Fibonacci numbers [1,1,2,3,5,8,13,21,...], the golden ratio phi=1.618..., and pi=3.14159... to create harmonic positional embeddings. These beat sinusoidal encodings in transformerless architectures.",
        meta: {source: "substrate docs", topic: "math"}
    },
    {
        text: "llm_call(prompt, model, system) is a native OMC builtin that calls the Anthropic Claude API. It reads ANTHROPIC_API_KEY from the environment. The default model is claude-opus-4-5.",
        meta: {source: "builtins ref", topic: "api"}
    },
    {
        text: "eval_omc(code_string) executes an OMC string at runtime. Combined with llm_call, it enables recursive self-improvement: OMC programs can ask Claude to write new OMC code and then run it.",
        meta: {source: "builtins ref", topic: "meta"}
    },
    {
        text: "par_map(fn, array) runs fn on each element of array in parallel. OMC also provides par_filter and par_reduce. These enable fast batch LLM calls via batch_llm_call.",
        meta: {source: "stdlib ref", topic: "parallel"}
    },
    {
        text: "The OMC memory system uses fibtier (Fibonacci-tier) bounded storage. It integrates with the OMC proxy (apiproxy) which compresses LLM context windows using substrate-aware tokenization.",
        meta: {source: "architecture docs", topic: "memory"}
    },
    {
        text: "OMC supports Python interop via PyO3. You can call Python functions from OMC using py_call, py_eval, and py_import. This enables NumPy, Pandas, PyTorch, and sklearn from OMC programs.",
        meta: {source: "python docs", topic: "interop"}
    },
    {
        text: "The Prometheus engine in OMC is a full neural network training framework. It includes tape-based autograd, substrate-native attention, CRT-Fibonacci positional encoding, and GPU acceleration via wgpu.",
        meta: {source: "prometheus docs", topic: "ml"}
    }
]

# Index documents using native substrate_embed (no API key, pure math)
print("=== Substrate RAG demo ===")
print("Indexing documents with native substrate_embed (offline, no API key)...")
h i = 0
while i < arr_len(DOCUMENTS) {
    h doc = DOCUMENTS[i]
    docstore_add(KB, doc["text"], doc["meta"])
    i += 1
}
print(str_concat("Indexed ", to_string(arr_len(DOCUMENTS)), " documents"))
print("")

# ── Part 1: Pure substrate retrieval (offline) ────────────────────────────────

print("--- Part 1: Offline substrate retrieval ---")
h QUERIES = [
    "How does OMC call Claude?",
    "What is the phi-pi-fibonacci substrate?",
    "Can OMC use Python libraries?",
    "How does recursive self-improvement work in OMC?"
]

h qi = 0
while qi < arr_len(QUERIES) {
    h qtext = QUERIES[qi]
    h retrieved = docstore_search(KB, qtext, 1)
    h top = retrieved[0]
    print(str_concat("Q: ", qtext))
    print(str_concat("  Best match (sim=", to_string(top["score"]), "): '", str_slice(top["text"], 0, 80), "...'"))
    print("")
    qi += 1
}

# ── Part 2: str_similarity demo (uses same substrate math) ───────────────────

print("--- Part 2: str_similarity (same substrate math, no API) ---")
h pairs = [
    ["phi-pi-fibonacci harmonic embeddings", "Fibonacci golden ratio substrate math"],
    ["phi-pi-fibonacci harmonic embeddings", "Python neural network PyTorch training"],
    ["OMC self-hosting language", "OMC recursive self-improvement"],
    ["OMC self-hosting language", "NFL football scores statistics"]
]
h pi2 = 0
while pi2 < arr_len(pairs) {
    h pair = pairs[pi2]
    h strsim = str_similarity(pair[0], pair[1])
    print(str_concat("  '", str_slice(pair[0], 0, 35), "' vs '", str_slice(pair[1], 0, 35), "' => ", to_string(strsim)))
    pi2 += 1
}
print("")

# ── Part 3: Full RAG with LLM answer ─────────────────────────────────────────

print("--- Part 3: RAG answer via LLM ---")
h LLM_QUESTIONS = [
    "How does recursive self-improvement work in OMC?",
    "What is Prometheus in OMC?"
]
h lqi = 0
while lqi < arr_len(LLM_QUESTIONS) {
    h question = LLM_QUESTIONS[lqi]
    print(str_concat("Q: ", question))
    h result = rag_answer(KB, question, 2, null)
    print(str_concat("A: ", str_slice(result["answer"], 0, 200)))
    print("")
    lqi += 1
}

print("=== Substrate RAG complete ===")
