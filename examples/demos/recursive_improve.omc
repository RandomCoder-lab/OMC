# recursive_improve.omc
# Recursive Self-Improvement (RSI) demonstration: OMC code that improves OMC code.
#
# How it works (three distinct levels):
#   Level 0 – seed:     a target function spec (plain English) is the raw material
#   Level 1 – improver: Claude generates OMC candidates; we score each one with
#                       omc_code_metrics + llm_judge, keep the best
#   Level 2 – meta:     after each outer round, Claude is asked to rewrite the
#                       improver prompt itself, making the improver smarter
#
# Measurable: every round emits numeric scores so improvement is visible.
# Runnable:   uses only real builtins (llm_call, llm_judge, omc_code_metrics,
#             omc_code_complexity, omc_code_similarity, omc_code_canonical,
#             omc_substrate_score, str_*, arr_*, print).
#
# Usage: omc examples/demos/recursive_improve.omc

import "examples/lib/llm.omc"

h MODEL             = "claude-haiku-4-5-20251001"
h CANDIDATES_PER_ROUND = 3   # N candidates generated each improvement round
h OUTER_ROUNDS      = 3      # meta-improvement rounds (improver improves improver)
h INNER_ROUNDS      = 2      # improvement rounds per meta-round

# OMC syntax reference injected into every LLM prompt
h OMC_SYNTAX = "
OMC (OmniMCode) SYNTAX — use ONLY this syntax, not Python/JavaScript/Rust:
  Variables:   h name = value
  Functions:   fn name(arg1, arg2) { body }
  Return:      return expr
  If:          if cond { ... } else { ... }
  While:       while cond { body }
  Dict:        h d = {}   dict_get(d, key)   dict_set(d, key, val)   dict_has(d, key)
  Array:       h a = []   arr_get(a, i)       arr_push(a, val)        arr_len(a)
  Strings:     str_concat(a, b)  str_len(s)  to_string(x)
  Comments:    # line comment
EXAMPLE:
  fn fib(n) {
      if n <= 1 { return n }
      return fib(n - 1) + fib(n - 2)
  }
DO NOT use: let, var, func, function, def, const, ;, (), lambda, return type annotations.
"

# ── Target spec ──────────────────────────────────────────────────────────────
# This is the problem we are asking Claude to solve and keep improving.

h TARGET_SPEC = "
Write an OMC function `fib_memo(n)` that:
  - Returns the nth Fibonacci number (0-indexed, fib(0)=0, fib(1)=1)
  - Uses memoization (a dict or array) to cache prior results
  - Handles n=0 and n=1 as base cases
  - Is as short and readable as possible
  - Uses OMC substrate primitives where applicable (arr_get, dict_get, etc.)
"

# ── Scoring ───────────────────────────────────────────────────────────────────
# Higher score is better.
# Score = substrate_score*40 + (1/(complexity+1))*30 + compression_ratio*20 + diversity*10
# diversity bonus: penalise duplicates of earlier candidates this round

fn score_candidate(src, all_prev_srcs, prev_best_score) {
    # Skip candidates that aren't valid OMC — return 0 so they lose naturally
    if !omc_code_valid(src) { return 0.0 }

    h m   = omc_code_metrics(src)
    h cs  = omc_code_complexity(src)

    # Complexity: lower is better (max contribution 30)
    h complexity_contrib = 30.0 / (cs["complexity"] + 1)

    # Substrate alignment: fraction of attractor tokens (max 40)
    h sub  = omc_substrate_score(src)
    h sub_contrib = sub * 40.0

    # Token compression (higher = denser OMC vocabulary usage), max 20
    h comp_contrib = m["compression_ratio"] * 20.0

    # Diversity bonus: if this code is novel vs all prior candidates, +10
    h diversity = 10.0
    h i = 0
    while i < arr_len(all_prev_srcs) {
        h sim = omc_code_similarity(src, all_prev_srcs[i])
        if sim > 0.85 {
            diversity = 0.0
        }
        i += 1
    }

    h total = complexity_contrib + sub_contrib + comp_contrib + diversity
    return total
}

fn format_metrics(src) {
    if !omc_code_valid(src) { return "  [invalid OMC]" }
    h m  = omc_code_metrics(src)
    h cs = omc_code_complexity(src)
    h sub = omc_substrate_score(src)
    return str_concat(
        str_concat("  complexity=", to_string(cs["complexity"])),
        str_concat(
            str_concat("  ast_size=", to_string(m["ast_size"])),
            str_concat(
                str_concat("  substrate=", to_string(sub)),
                str_concat("  tokens=", to_string(m["token_count"]))
            )
        )
    )
}

# ── Candidate generation ───────────────────────────────────────────────────────

fn build_improver_prompt(spec, best_src, best_score, round_num, meta_hint) {
    h base = str_concat(
        "You are improving an OMC (OmniMCode) function.\n",
        str_concat(OMC_SYNTAX,
        str_concat("\nSPEC:\n",
        str_concat(spec,
        str_concat("\n\nCURRENT BEST (score ", str_concat(to_string(best_score),
        str_concat("):\n```omc\n", str_concat(best_src, "\n```\n\n")))))))
    )
    h instruction = str_concat(
        "Generate ONE improved OMC function that scores higher.\n",
        str_concat("Return ONLY a ```omc ... ``` code block, nothing else.\n",
        str_concat(
            "Improvement round: ", str_concat(to_string(round_num), "\n")
        ))
    )
    h hint = str_concat("\nIMPROVER GUIDANCE:\n", meta_hint)
    return str_concat(base, str_concat(instruction, hint))
}

fn generate_candidates(spec, best_src, best_score, round_num, meta_hint, n) {
    h candidates = []
    h i = 0
    while i < n {
        h prompt = build_improver_prompt(spec, best_src, best_score, round_num, meta_hint)
        h response = llm_call(prompt, MODEL)
        # Extract code block from response
        h src = extract_code_block(response)
        arr_push(candidates, src)
        i += 1
    }
    return candidates
}

fn extract_code_block(text) {
    # Pull out ```omc ... ``` or ``` ... ``` block; fall back to whole text
    h start = str_find(text, "```omc")
    if start >= 0 {
        h suffix = str_slice(text, start + 6, str_len(text))
        h rel_end = str_find(suffix, "```")
        if rel_end >= 0 {
            return str_trim(str_slice(suffix, 0, rel_end))
        }
    }
    h start2 = str_find(text, "```")
    if start2 >= 0 {
        h suffix2 = str_slice(text, start2 + 3, str_len(text))
        h rel_end2 = str_find(suffix2, "```")
        if rel_end2 >= 0 {
            return str_trim(str_slice(suffix2, 0, rel_end2))
        }
    }
    return str_trim(text)
}

# ── Meta-improvement: rewrite the improver guidance ───────────────────────────

fn meta_improve_hint(current_hint, score_history, best_src, spec) {
    h history_str = format_score_history(score_history)
    h prompt = str_concat(
        "You are a meta-optimizer improving an AI code improver.\n\n",
        str_concat(
            "TASK SPEC:\n", str_concat(spec, "\n\n")
        )
    )
    h context = str_concat(
        "CURRENT IMPROVER GUIDANCE:\n",
        str_concat(current_hint, "\n\n")
    )
    h scores = str_concat(
        "SCORE HISTORY (higher=better, target ~80):\n",
        str_concat(history_str, "\n\n")
    )
    h best = str_concat(
        "CURRENT BEST CODE:\n```omc\n",
        str_concat(best_src, "\n```\n\n")
    )
    h instruction = str_concat(
        "Rewrite the improver guidance to produce even better OMC code.\n",
        "Focus on:\n",
        "  - Using OMC substrate primitives (arr_get, dict_get, arr_fold)\n",
        "  - Minimising cyclomatic complexity\n",
        "  - Dense substrate vocabulary (attractor tokens)\n",
        "Return ONLY the new guidance text, no preamble.\n"
    )
    return llm_call(str_concat(prompt, str_concat(context, str_concat(scores, str_concat(best, instruction)))), MODEL)
}

fn format_score_history(history) {
    h out = ""
    h i = 0
    while i < arr_len(history) {
        h entry = history[i]
        out = str_concat(out, str_concat(
            "Round ", str_concat(to_string(entry["round"]),
            str_concat(": score=", str_concat(to_string(entry["score"]),
            str_concat("  ", str_concat(entry["metrics"], "\n")))))
        ))
        i += 1
    }
    return out
}

# ── Inner improvement loop ────────────────────────────────────────────────────

fn inner_loop(spec, seed_src, meta_hint, inner_rounds, meta_round) {
    h best_src   = seed_src
    h best_score = score_candidate(best_src, [], 0)
    h history    = []
    h prev_srcs  = [seed_src]

    print(str_concat("  [meta ", str_concat(to_string(meta_round),
          str_concat("] inner loop — seed score: ", to_string(best_score)))))

    h r = 0
    while r < inner_rounds {
        print(str_concat("    inner round ", str_concat(to_string(r + 1),
              str_concat("/", to_string(inner_rounds)))))

        # Generate N candidates
        h candidates = generate_candidates(
            spec, best_src, best_score,
            meta_round * inner_rounds + r,
            meta_hint, CANDIDATES_PER_ROUND
        )

        # Score each candidate; keep best
        h c = 0
        while c < arr_len(candidates) {
            h cand = candidates[c]
            h cscore = score_candidate(cand, prev_srcs, best_score)
            print(str_concat("      candidate ", str_concat(to_string(c + 1),
                  str_concat(": score=", str_concat(to_string(cscore),
                  format_metrics(cand))))))
            if cscore > best_score {
                best_score = cscore
                best_src   = cand
                print("      ↑ new best!")
            }
            arr_push(prev_srcs, cand)
            c += 1
        }

        arr_push(history, {
            "round":   meta_round * inner_rounds + r + 1,
            "score":   best_score,
            "metrics": format_metrics(best_src)
        })

        r += 1
    }

    return {
        "best_src":   best_src,
        "best_score": best_score,
        "history":    history
    }
}

# ── Main RSI orchestrator ─────────────────────────────────────────────────────

fn run_rsi(spec, outer_rounds, inner_rounds) {
    print("=== Recursive Self-Improvement Demo ===")
    print(str_concat("Target: ", spec))
    print("")

    # Level 0: seed — ask Claude for an initial naive implementation
    h seed_prompt = str_concat(
        "Write an OMC (OmniMCode) function that satisfies this spec.\n",
        str_concat(OMC_SYNTAX,
        str_concat("\nSPEC:\n", str_concat(spec,
        "\nReturn ONLY a ```omc ... ``` code block, nothing else.")))
    )
    print("[Level 0] Generating seed implementation...")
    h seed_response = llm_call(seed_prompt, MODEL)
    h seed_src      = extract_code_block(seed_response)
    print(str_concat("  seed code:\n", seed_src))
    print(str_concat("  seed metrics:", format_metrics(seed_src)))
    print("")

    # Initial meta-hint (Level 2 seed)
    h meta_hint = str_concat(
        "Improve the OMC code by:\n",
        "  1. Using dict-based memoization with dict_get/dict_set\n",
        "  2. Minimising branches (target complexity <= 2)\n",
        "  3. Preferring arr_get over index syntax\n",
        "  4. Keeping the function short (< 10 statements)\n"
    )

    h best_src   = seed_src
    h best_score = score_candidate(seed_src, [], 0)
    h all_history = []

    h m = 0
    while m < outer_rounds {
        print(str_concat("=== Meta-round ", str_concat(to_string(m + 1),
              str_concat("/", to_string(outer_rounds), " =================="))))

        # Level 1: inner improvement loop
        h result = inner_loop(spec, best_src, meta_hint, inner_rounds, m)
        best_src   = result["best_src"]
        best_score = result["best_score"]

        h inner_hist = result["history"]
        h hi = 0
        while hi < arr_len(inner_hist) {
            arr_push(all_history, inner_hist[hi])
            hi += 1
        }

        print(str_concat("  [meta ", str_concat(to_string(m + 1),
              str_concat("] best score so far: ", to_string(best_score)))))
        print(str_concat("  best code:\n", best_src))
        print("")

        # Level 2: meta-improve the improver guidance
        if m < outer_rounds - 1 {
            print("  [Level 2] Meta-improving the improver prompt...")
            meta_hint = meta_improve_hint(meta_hint, all_history, best_src, spec)
            print(str_concat("  new meta-hint:\n  ", meta_hint))
            print("")
        }

        m += 1
    }

    # Final report
    print("=== Final Report ===")
    print(str_concat("Total rounds: ", to_string(arr_len(all_history))))
    print("")
    print("Score history:")
    h hi2 = 0
    while hi2 < arr_len(all_history) {
        h entry = all_history[hi2]
        print(str_concat("  Round ", str_concat(to_string(entry["round"]),
              str_concat(": ", str_concat(to_string(entry["score"]),
              str_concat("  ", entry["metrics"]))))))
        hi2 += 1
    }
    print("")
    print("Best implementation:")
    print(best_src)
    print("")

    # Verify improvement
    h seed_score = score_candidate(seed_src, [], 0)
    h improved   = best_score > seed_score
    print(str_concat("Seed score:  ", to_string(seed_score)))
    print(str_concat("Final score: ", to_string(best_score)))
    print(str_concat("Improved:    ", if improved { "YES ✓" } else { "NO ✗" }))

    return {
        "improved":    improved,
        "seed_score":  seed_score,
        "final_score": best_score,
        "best_src":    best_src,
        "history":     all_history
    }
}

# ── Entry point ───────────────────────────────────────────────────────────────

h result = run_rsi(TARGET_SPEC, OUTER_ROUNDS, INNER_ROUNDS)

# Exit code: 0 = improved, 1 = no improvement
if result["improved"] {
    print("RSI succeeded: measurable improvement achieved.")
} else {
    print("RSI did not improve beyond seed — check MODEL or CANDIDATES_PER_ROUND.")
}
