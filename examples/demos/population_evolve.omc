# population_evolve.omc
# Genetic programming with Claude as the mutation operator.
# A population of OMC functions evolves across generations toward a fitness goal.

import "examples/lib/llm.omc"
import "examples/lib/cache.omc"

h MODEL = "claude-opus-4-5"
h POP_SIZE = 5
h GENERATIONS = 4
h MUTATION_RATE = 0.7
h ELITE_COUNT = 2

h eval_cache = lru_new(200)

# ── Fitness function ─────────────────────────────────────────────────────────

fn compute_fitness(code, test_cases) {
    h cache_key = code
    h cached = lru_get(eval_cache, cache_key)
    if cached != null { return cached }

    h passed = 0
    h total = arr_len(test_cases)
    h i = 0
    while i < total {
        h tc = test_cases[i]
        h test_code = str_concat(
            code, "\n",
            "h __result = target_fn(", json_stringify(tc["input"]), ")\n",
            "__result"
        )
        h run = eval_omc(test_code)
        h ok = false
        h got = run
        if type_of(run) == type_of(tc["expected"]) {
            if run == tc["expected"] { ok = true }
        }
        if ok { passed = passed + 1 }
        i = i + 1
    }
    h fitness = passed / total
    lru_put(eval_cache, cache_key, fitness)
    return fitness
}

# ── Population initialization ─────────────────────────────────────────────────


fn init_population(problem, pop_size) {
    # Build all spawn prompts at once and fire in parallel via batch_llm_call
    h variety_hint = ["", " Think creatively.", " Use a different algorithm.", " Optimize for readability.", " Use recursion if possible."]
    h sys = str_concat(
        "Write an OMC function named target_fn that solves: ", problem, "\n",
        "Use h for bindings, fn for functions, while for loops.\n",
        "Return ONLY the OMC code, no explanation."
    )
    h prompts = []
    h i = 0
    while i < pop_size {
        h hint = variety_hint[i % arr_len(variety_hint)]
        h p = str_concat("Write target_fn for: ", problem, hint)
        arr_push(prompts, {prompt: p, system: sys})
        i = i + 1
    }
    print(str_concat("  Spawning ", to_string(pop_size), " individuals in parallel..."))
    h raw_codes = batch_llm_call(prompts, MODEL)
    h population = []
    h ci = 0
    while ci < arr_len(raw_codes) {
        h code = raw_codes[ci]
        if str_contains(code, "```") {
            h parts = str_split(code, "```")
            if arr_len(parts) >= 3 {
                code = str_trim(parts[1])
                if str_starts_with(code, "omc\n") { code = str_slice(code, 4, str_len(code)) }
            }
        }
        arr_push(population, {code: str_trim(code), fitness: 0.0})
        ci = ci + 1
    }
    return population
}

# ── Genetic operators ─────────────────────────────────────────────────────────


# ── Selection ─────────────────────────────────────────────────────────────────

fn evaluate_population(population, test_cases) {
    h i = 0
    while i < arr_len(population) {
        h fitness = compute_fitness(population[i]["code"], test_cases)
        population[i]["fitness"] = fitness
        i = i + 1
    }
    # sort by fitness descending (bubble sort)
    h n = arr_len(population)
    h si = 0
    while si < n {
        h sj = si + 1
        while sj < n {
            if population[sj]["fitness"] > population[si]["fitness"] {
                h tmp = population[si]
                population[si] = population[sj]
                population[sj] = tmp
            }
            sj = sj + 1
        }
        si = si + 1
    }
    return population
}

fn tournament_select(population) {
    # pick 2 random (by modding fitness hash) and return better one
    h a = population[0]
    h b = population[1 % arr_len(population)]
    if a["fitness"] >= b["fitness"] { return a }
    return b
}

# ── Main evolution loop ───────────────────────────────────────────────────────

fn evolve(problem, test_cases, pop_size, generations, elite_count) {
    print(str_concat("Problem: ", problem))
    print(str_concat("Population: ", to_string(pop_size), " | Generations: ", to_string(generations)))
    print("")

    print("Initializing population...")
    h population = init_population(problem, pop_size)

    h best_fitness = 0.0
    h best_code = ""
    h stats = []

    h gen = 0
    while gen < generations {
        print(str_concat("--- Generation ", to_string(gen + 1), " ---"))

        population = evaluate_population(population, test_cases)

        h gen_best = population[0]["fitness"]
        h gen_avg = 0.0
        h gi = 0
        while gi < arr_len(population) {
            gen_avg = gen_avg + population[gi]["fitness"]
            gi = gi + 1
        }
        gen_avg = gen_avg / arr_len(population)

        print(str_concat("  Best: ", to_string(gen_best * 100), "% | Avg: ", to_string(gen_avg * 100), "%"))

        if gen_best > best_fitness {
            best_fitness = gen_best
            best_code = population[0]["code"]
        }

        arr_push(stats, {gen: gen + 1, best: gen_best, avg: gen_avg})

        if best_fitness >= 1.0 {
            print("  ✓ Perfect fitness achieved!")
            break
        }

        if gen + 1 >= generations { break }

        # Next generation
        h next_pop = []

        # Elites survive unchanged
        h ei = 0
        while ei < elite_count and ei < arr_len(population) {
            arr_push(next_pop, population[ei])
            ei = ei + 1
        }

        # Build mutation/crossover prompts in batch for parallelism
        h mutation_types = ["refactor for clarity", "add edge case handling", "optimize the algorithm", "rewrite using a different approach", "improve variable naming"]
        h mut_sys = "You write OMC code. Return ONLY code, no markdown, no explanation."
        h batch_prompts = []
        h ni = 0
        while ni < pop_size - elite_count {
            h parent_a = tournament_select(population)
            h mut_type = mutation_types[ni % arr_len(mutation_types)]
            h p = ""
            if ni % 3 == 0 and arr_len(population) >= 2 {
                h parent_b = tournament_select(population)
                p = str_concat(
                    "Combine the best aspects of these two OMC functions into one better implementation.\n\n",
                    "Function A:\n", parent_a["code"], "\n\n",
                    "Function B:\n", parent_b["code"], "\n\n",
                    "Task: ", problem, "\n",
                    "Return only the combined OMC function named target_fn."
                )
            } else {
                p = str_concat(
                    "Mutate this OMC function (", mut_type, "):\n\n",
                    parent_a["code"], "\n\n",
                    "Must still solve: ", problem, "\nReturn only the mutated OMC code."
                )
            }
            arr_push(batch_prompts, {prompt: p, system: mut_sys})
            ni = ni + 1
        }

        # Fire all mutations/crossovers in parallel
        h mut_results = batch_llm_call(batch_prompts, MODEL)
        h mri = 0
        while mri < arr_len(mut_results) {
            h code = mut_results[mri]
            if str_contains(code, "```") {
                h parts = str_split(code, "```")
                if arr_len(parts) >= 3 { code = str_trim(parts[1]) }
            }
            arr_push(next_pop, {code: str_trim(code), fitness: 0.0})
            mri = mri + 1
        }

        population = next_pop
        gen = gen + 1
    }

    return {
        best_code: best_code,
        best_fitness: best_fitness,
        generations: gen + 1,
        stats: stats
    }
}

# ── Problem definition ────────────────────────────────────────────────────────

h PROBLEM = "Write target_fn(n) that returns the sum of all prime numbers up to n (inclusive)."
h TEST_CASES = [
    {input: 10, expected: 17},
    {input: 20, expected: 77},
    {input: 5, expected: 5},
    {input: 2, expected: 2},
    {input: 1, expected: 0}
]

print("=== Genetic Programming: Evolving OMC Code with Claude ===")
print("")

h result = evolve(PROBLEM, TEST_CASES, POP_SIZE, GENERATIONS, ELITE_COUNT)

print("")
print("=== Evolution Complete ===")
print(str_concat("Best fitness: ", to_string(result["best_fitness"] * 100), "%"))
print(str_concat("Generations: ", to_string(result["generations"])))
print("")
print("Best evolved code:")
print(result["best_code"])
