# Substrate-aware parameter init A/B (#281 weave-in test).
#
# Hypothesis: starting weights at substrate-aligned positions (snapped to
# nearest Fibonacci attractor at init scale) gives different training
# trajectories than uniform random init. PyTorch literature has no analog
# — substrate-aware init is OMC-native via the phi_pi_fib primitive.
#
# Three arms, all L1+SMOD+V single-head, 3 seeds, 400 steps:
#   A. baseline   _prom_random_matrix uniform
#   B. snap=1024  init then substrate_snap_matrix(W, 1024)
#   C. snap=4096  init then substrate_snap_matrix(W, 4096)
#
# Wins/ties: does substrate-init regularize? does scale matter?

import "examples/lib/prometheus.omc";

fn build_vocab(text) {
    h seen = dict_new();
    h chars = [];
    h i = 0;
    while i < str_len(text) {
        h ch = str_slice(text, i, i + 1);
        if !dict_has(seen, ch) { dict_set(seen, ch, arr_len(chars)); arr_push(chars, ch); }
        i = i + 1;
    }
    h v = dict_new();
    dict_set(v, "chars", chars);
    dict_set(v, "lookup", seen);
    return v;
}

fn encode(text, vocab) {
    h lookup = dict_get(vocab, "lookup");
    h ids = [];
    h i = 0;
    while i < str_len(text) {
        h ch = str_slice(text, i, i + 1);
        arr_push(ids, dict_get(lookup, ch));
        i = i + 1;
    }
    return ids;
}

# Apply substrate snap to all parameter matrices in a layer dict.
fn snap_all_params(params, scale) {
    if scale == 0.0 { return; }
    h i = 0;
    while i < arr_len(params) {
        h node = arr_get(params, i);
        h v = tape_value(node);
        # tape_value may return scalar (1x1) or 1D row; substrate_snap_matrix
        # only handles arrays, so guard.
        if dict_has(_value_type_dispatch(v), "ok") {
            h snapped = substrate_snap_matrix(v, scale);
            tape_set_value(node, snapped);
        }
        i = i + 1;
    }
}

# Cheap "is this an array?" check — returns a dict with "ok" key when v
# is an array (i.e. has arr_len defined).
fn _value_type_dispatch(v) {
    h out = dict_new();
    # Try arr_len; if v is a float/int we'd error. OMC has no try/catch,
    # so check by attempted indirection — instead just use a sentinel
    # approach: bias matrices are 1D arrays, Q/V/W are 2D, both work
    # with substrate_snap_matrix. Always return ok; if v is scalar the
    # builtin's error message is the bug we'll see in practice.
    dict_set(out, "ok", 1);
    return out;
}

fn build_model(snap_scale, vocab_size, d_model, ff_dim, seq_len, seed) {
    h emb = prom_embedding_new(vocab_size, d_model, seed);
    h s1 = dict_get(emb, "rng_state");
    h attn = prom_attention_substrate_k_new(d_model, seq_len, s1 + 11);
    h s2 = dict_get(attn, "rng_state");
    h ln1 = prom_layernorm_new(d_model, s2);
    h ff_up = prom_linear_new(d_model, ff_dim, s2 + 13);
    h s3 = dict_get(ff_up, "rng_state");
    h ff_down = prom_linear_new(ff_dim, d_model, s3);
    h s4 = dict_get(ff_down, "rng_state");
    h ln2 = prom_layernorm_new(d_model, s4);
    h head = prom_linear_new(d_model, vocab_size, s4 + 17);
    h m = dict_new();
    dict_set(m, "emb", emb);
    dict_set(m, "attn", attn);
    dict_set(m, "ln1", ln1);
    dict_set(m, "ff_up", ff_up);
    dict_set(m, "ff_down", ff_down);
    dict_set(m, "ln2", ln2);
    dict_set(m, "head", head);
    # Snap embedding table + attn Q/V + linear Ws (2D matrices only).
    if snap_scale > 0.0 {
        h t = dict_get(emb, "table");
        h tv = tape_value(t);
        tape_set_value(t, substrate_snap_matrix(tv, snap_scale));
        h Q = dict_get(attn, "Q");
        tape_set_value(Q, substrate_snap_matrix(tape_value(Q), snap_scale));
        h V = dict_get(attn, "V");
        tape_set_value(V, substrate_snap_matrix(tape_value(V), snap_scale));
        h ffu = dict_get(ff_up, "W");
        tape_set_value(ffu, substrate_snap_matrix(tape_value(ffu), snap_scale));
        h ffd = dict_get(ff_down, "W");
        tape_set_value(ffd, substrate_snap_matrix(tape_value(ffd), snap_scale));
        h hd = dict_get(head, "W");
        tape_set_value(hd, substrate_snap_matrix(tape_value(hd), snap_scale));
    }
    return m;
}

fn forward_window(model, token_ids, pe_table) {
    h x = prom_embedding_batch(dict_get(model, "emb"), token_ids);
    h pe_rows = [];
    h i = 0;
    while i < arr_len(token_ids) { arr_push(pe_rows, arr_get(pe_table, i)); i = i + 1; }
    x = tape_add(x, tape_const(pe_rows));
    h attn_out = prom_attention_substrate_k_forward(dict_get(model, "attn"), x);
    h x_post = tape_add(x, attn_out);
    h n1 = prom_layernorm_forward(dict_get(model, "ln1"), x_post);
    h up = prom_linear_forward(dict_get(model, "ff_up"), n1);
    h down = prom_linear_forward(dict_get(model, "ff_down"), prom_relu(up));
    h x_ff = tape_add(x_post, down);
    h n2 = prom_layernorm_forward(dict_get(model, "ln2"), x_ff);
    return prom_linear_forward(dict_get(model, "head"), n2);
}

fn collect_all(model) {
    h attn_p = prom_attention_substrate_k_params(dict_get(model, "attn"));
    h other = prom_collect_params_v2([
        dict_get(model, "emb"),
        dict_get(model, "ln1"),
        dict_get(model, "ff_up"),
        dict_get(model, "ff_down"),
        dict_get(model, "ln2"),
        dict_get(model, "head"),
    ]);
    h out = [];
    h i = 0;
    while i < arr_len(attn_p) { arr_push(out, arr_get(attn_p, i)); i = i + 1; }
    i = 0;
    while i < arr_len(other) { arr_push(out, arr_get(other, i)); i = i + 1; }
    return out;
}

fn train(snap_scale, vocab_size, ids, seq_len, d_model, ff_dim, lr, steps, seed) {
    tape_reset();
    h model = build_model(snap_scale, vocab_size, d_model, ff_dim, seq_len, seed);
    h params = collect_all(model);
    h opt = prom_adamw_new(params, lr, 0.9, 0.999, 1e-8, 0.0);
    h pe_table = prom_crt_pe_matrix(seq_len, d_model);
    h n_windows = arr_len(ids) - seq_len - 1;
    h tail = [];
    h step = 0;
    while step < steps {
        h start = step - (step / n_windows) * n_windows;
        h window = [];
        h targets = [];
        h k = 0;
        while k < seq_len {
            arr_push(window, arr_get(ids, start + k));
            arr_push(targets, arr_get(ids, start + k + 1));
            k = k + 1;
        }
        h logits = forward_window(model, window, pe_table);
        h loss = prom_cross_entropy_batch(logits, targets, vocab_size);
        tape_backward(loss);
        prom_adamw_step(opt);
        if step >= steps - 30 { arr_push(tail, tape_value(loss)); }
        step = step + 1;
    }
    h s = 0.0;
    h i = 0;
    while i < arr_len(tail) { s = s + arr_get(tail, i); i = i + 1; }
    return s / arr_len(tail);
}

fn mean_arr(xs) {
    h s = 0.0; h i = 0;
    while i < arr_len(xs) { s = s + arr_get(xs, i); i = i + 1; }
    return s / arr_len(xs);
}

fn main() {
    print("=== substrate-init A/B (#281 weave-in test) ===");
    h text = "the rain in spain falls mainly on the plain and the sun rises in the east while the moon hides behind the mountain peaks of distant lands where ancient creatures sleep in caves of silver beneath the stars while waves crash against rocky shores carrying secrets older than time itself";
    h vocab = build_vocab(text);
    h vocab_size = arr_len(dict_get(vocab, "chars"));
    h ids = encode(text, vocab);
    h seq_len = 8;
    h d_model = 16;
    h ff_dim = 32;
    h lr = 0.01;
    h steps = 300;
    h seeds = [42, 7, 123, 2026, 99, 1];

    h scales = [0.0, 1024.0, 4096.0];
    h labels = ["baseline ", "snap=1024", "snap=4096"];

    h results = [];
    h ai = 0;
    while ai < arr_len(scales) {
        h scale = arr_get(scales, ai);
        h label = arr_get(labels, ai);
        h losses = [];
        h si = 0;
        while si < arr_len(seeds) {
            h seed = arr_get(seeds, si);
            h L = train(scale, vocab_size, ids, seq_len, d_model, ff_dim, lr, steps, seed);
            arr_push(losses, L);
            si = si + 1;
        }
        h mu = mean_arr(losses);
        print(concat_many(label, " mean=", to_string(mu)));
        arr_push(results, losses);
        ai = ai + 1;
    }

    print("");
    print("=== headline ===");
    h base_mu = mean_arr(arr_get(results, 0));
    ai = 0;
    while ai < arr_len(scales) {
        h label = arr_get(labels, ai);
        h losses = arr_get(results, ai);
        h mu = mean_arr(losses);
        h pct = ((mu - base_mu) / base_mu) * 100.0;
        h wins = 0;
        h si = 0;
        h base_losses = arr_get(results, 0);
        while si < arr_len(seeds) {
            if arr_get(losses, si) < arr_get(base_losses, si) { wins = wins + 1; }
            si = si + 1;
        }
        print(concat_many(label, " mean=", to_string(mu),
            "  Δ=", to_string(mu - base_mu),
            "  (", to_string(pct), "%)",
            "  wins ", to_string(wins), "/", to_string(arr_len(seeds))));
        ai = ai + 1;
    }
}

main();
