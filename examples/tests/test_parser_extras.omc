# Regression tests for parser correctness.

fn assert_eq(actual, expected, msg) {
    if actual != expected {
        test_record_failure(msg + ": expected " + to_string(expected) + " got " + to_string(actual));
    }
}

fn assert_true(cond, msg) { if !cond { test_record_failure(msg); } }

# ---- chained index on call result ----

fn _pair(a, b) { return {"a": a, "b": b}; }

fn test_chained_index_on_call_result() {
    h p = _pair(10, 20);
    assert_eq(p["a"], 10, "dict index via var");
    assert_eq(p["b"], 20, "dict index via var b");
}

fn _make_val(v) { return {"val": v * 2}; }

fn _doubled(x) { return _make_val(x)["val"]; }

fn test_chained_index_in_return() {
    # Regression: `return call(args)["key"]` correctly returns the field,
    # not the whole dict.
    assert_eq(_doubled(5), 10, "return call()[key]");
    assert_eq(_doubled(0), 0, "return call()[key] zero");
    assert_eq(_doubled(7), 14, "return call()[key] seven");
}

fn _nested_dict() { return {"a": {"b": 99}}; }

fn test_double_chained_index_on_call() {
    h n = _nested_dict();
    assert_eq(n["a"]["b"], 99, "double index via var");
}

fn _get_dict() { return {"x": 5}; }

fn test_chained_index_in_assign() {
    h val = _get_dict()["x"];
    assert_eq(val, 5, "assign from call()[key]");
}

fn _flags() { return {"ok": 1}; }

fn test_chained_index_in_condition() {
    h hit = 0;
    if _flags()["ok"] == 1 { hit = 1; }
    assert_eq(hit, 1, "if call()[key]");
}

# ---- throw as return terminator ----

fn _always_throws(msg) { throw msg; }

fn test_throw_only_fn() {
    h caught = "";
    try {
        _always_throws("test-error");
    } catch e {
        caught = e;
    }
    assert_eq(caught, "test-error", "throw-only fn caught");
}

# ---- augmented assign /= ----

fn test_augmented_assign_divide() {
    h x = 100;
    x /= 4;
    assert_eq(x, 25, "x /= 4");
    h y = 10;
    y /= 2;
    assert_eq(y, 5, "y /= 2");
    h z = 7;
    z /= 1;
    assert_eq(z, 7, "z /= 1");
}

# ---- curried / expression-valued call: f(x)(y) ----

fn _make_adder(n) {
    return fn(x) { return x + n; };
}

fn _compose(f, g) {
    return fn(x) { return f(g(x)); };
}

fn _double(x) { return x * 2; }
fn _inc(x) { return x + 1; }

fn test_call_expr_basic() {
    assert_eq(_make_adder(5)(10), 15, "make_adder(5)(10)");
    assert_eq(_make_adder(0)(7), 7, "make_adder(0)(7)");
    assert_eq(_make_adder(100)(1), 101, "make_adder(100)(1)");
}

fn test_call_expr_compose() {
    h double_then_inc = _compose(_inc, _double);
    assert_eq(double_then_inc(3), 7, "compose: double then inc of 3");
    assert_eq(_compose(_double, _inc)(4), 10, "compose direct call");
}

fn test_call_expr_chained_index() {
    h reg = {"add5": _make_adder(5), "add10": _make_adder(10)};
    assert_eq(reg["add5"](3), 8, "reg[key](arg) add5");
    assert_eq(reg["add10"](3), 13, "reg[key](arg) add10");
}

fn _make_ops() {
    return [_make_adder(1), _make_adder(2), _make_adder(3)];
}

fn test_call_expr_array_index() {
    h ops = _make_ops();
    assert_eq(ops[0](10), 11, "arr[0](arg)");
    assert_eq(ops[2](10), 13, "arr[2](arg)");
}

# ---- exponentiation operator ** and **= ----

fn test_power_int() {
    assert_eq(2 ** 10, 1024, "2**10");
    assert_eq(3 ** 0, 1, "3**0");
    assert_eq(3 ** 1, 3, "3**1");
    assert_eq(5 ** 3, 125, "5**3");
}

fn test_power_float() {
    assert_eq(4.0 ** 0.5, 2.0, "4.0**0.5 = sqrt(4)");
    assert_eq(9.0 ** 0.5, 3.0, "9.0**0.5 = sqrt(9)");
}

fn test_power_right_assoc() {
    # 2 ** 3 ** 2 = 2 ** 9 = 512 (right-associative)
    assert_eq(2 ** 3 ** 2, 512, "2**3**2 right-assoc");
}

fn test_power_aug_assign() {
    h x = 3;
    x **= 3;
    assert_eq(x, 27, "x **= 3");
    h y = 2;
    y **= 8;
    assert_eq(y, 256, "y **= 8");
}

# ---- range(start, end, step) ----

fn test_range_step_forward() {
    h total = 0;
    for i in range(0, 10, 2) {
        total += i;
    }
    assert_eq(total, 20, "range(0,10,2) sum=20");
}

fn test_range_step_countdown() {
    h total = 0;
    for i in range(5, 0, -1) {
        total += i;
    }
    assert_eq(total, 15, "range(5,0,-1) sum=15");
}

fn test_range_step_skip() {
    h count = 0;
    for i in range(1, 10, 3) {
        count += 1;
    }
    assert_eq(count, 3, "range(1,10,3) has 3 elements: 1,4,7");
}
