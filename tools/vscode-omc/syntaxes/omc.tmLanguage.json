{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "OMNIcode",
  "scopeName": "source.omc",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#numbers" },
    { "include": "#functions" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#harmonic-builtins" }
  ],
  "repository": {
    "comments": {
      "match": "#.*$",
      "name": "comment.line.number-sign.omc"
    },
    "strings": {
      "name": "string.quoted.double.omc",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "match": "\\\\.", "name": "constant.character.escape.omc" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(if|elif|else|while|for|in|fn|h|return|break|continue|import|from|as|load|safe|try|catch|match|true|false|null)\\b",
          "name": "keyword.control.omc"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "\\b\\d+\\.\\d+\\b",
          "name": "constant.numeric.float.omc"
        },
        {
          "match": "\\b\\d+\\b",
          "name": "constant.numeric.integer.omc"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\bfn\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.function.omc" }
          }
        },
        {
          "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.call.omc" }
          }
        }
      ]
    },
    "harmonic-builtins": {
      "patterns": [
        {
          "match": "\\b(fold|fibonacci|fib|is_fibonacci|harmony_value|harmonic_partition|harmonic_sort|harmonic_index|harmonic_dedupe|phi|res|him)\\b",
          "name": "support.function.harmonic.omc"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "match": "\\b(int|float|string|bool|array|dict|function|null_t)\\b",
          "name": "support.type.builtin.omc"
        }
      ]
    },
    "operators": {
      "match": "(==|!=|<=|>=|<|>|\\+|-|\\*|/|%|=|->|=>|&&|\\|\\|)",
      "name": "keyword.operator.omc"
    }
  }
}
